# 环境变量文件（包含敏感密钥）
.env
.env.local
.env.production

# 知识库数据（包含实际业务数据）
knowledge/*
!knowledge/.gitkeep

# PPT 生成输出
projects/*
!projects/.gitkeep
test_output/
ppt-master/projects/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 虚拟环境
venv/
env/
.venv/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 日志文件
*.log
logs/

# Node.js 依赖
node_modules/
package-lock.json
yarn.lock

# 临时文件
*.tmp
*.temp
