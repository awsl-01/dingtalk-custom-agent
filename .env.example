# 钉钉开放平台配置
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_ROBOT_CODE=your_robot_code

# Claude API 配置
ANTHROPIC_API_KEY=your_anthropic_api_key
# 如果使用代理，填写代理地址
ANTHROPIC_BASE_URL=

# 服务配置
PORT=8913

# 知识库配置
KNOWLEDGE_DIR=knowledge

# Embedding配置
# 本地模型（优先使用，首次运行自动下载约100MB）
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# HuggingFace镜像（国内网络需要，解决下载超时问题）
HF_ENDPOINT=https://hf-mirror.com
# 远程API（备用，如不需要可留空）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# Rerank配置（可选，提升检索精度）
# 启用Rerank（默认关闭，需要额外依赖或API）
RERANK_ENABLED=false
# Rerank策略：local（本地cross-encoder）、llm（使用LLM）、api（第三方API）
RERANK_STRATEGY=llm
# 本地Cross-encoder模型（需要安装 sentence-transformers）
LOCAL_RERANK_MODEL=BAAI/bge-reranker-base
# Rerank API配置（如使用第三方API）
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=
# Rerank返回数量
RERANK_TOP_K=3

# 去重与版本控制配置
# 启用去重（默认开启）
DEDUP_ENABLED=true
# 启用版本控制（默认开启）
VERSION_CONTROL_ENABLED=true
# 版本控制策略：overwrite（覆盖旧版本）、keep（保留历史）、smart（智能判断）
VERSION_STRATEGY=smart
# 需要版本控制的类别（逗号分隔）
VERSION_CONTROLLED_CATEGORIES=schedule,exam

# 时效管理配置
# 启用时效管理（默认开启）
EXPIRY_ENABLED=true
# 各类别的默认过期时间（天数，0表示永不过期）
EXPIRY_DAYS_EXAM=30
EXPIRY_DAYS_NOTICE=90
EXPIRY_DAYS_HOMEWORK=7
EXPIRY_DAYS_SCHEDULE=0
EXPIRY_DAYS_CONTACT=0
EXPIRY_DAYS_TEACHING=365
EXPIRY_DAYS_STUDENT=0
EXPIRY_DAYS_OTHER=180
# 自动过期检查间隔（小时）
EXPIRY_CHECK_INTERVAL_HOURS=24
# 过期后是否自动删除（false则标记为过期但保留）
EXPIRY_AUTO_DELETE=false

# 使用统计与维护提醒配置
# 启用使用统计（默认开启）
USAGE_STATS_ENABLED=true
# 低频知识阈值（天数）：超过此天数未被检索的知识块视为低频
LOW_FREQUENCY_DAYS=30
# 无效知识阈值（天数）：超过此天数未被检索的知识块视为无效
USELESS_DAYS=90
# 最小访问次数：低于此次数且超过低频阈值的知识块需要审核
MIN_ACCESS_COUNT=3
# 维护提醒检查间隔（小时，默认7天）
MAINTENANCE_CHECK_INTERVAL_HOURS=168

# 主动智能配置
# 启用主动通知（默认开启）
PROACTIVE_NOTIFICATIONS_ENABLED=true
# 启用周期性提醒（默认开启）
PROACTIVE_REMINDER_ENABLED=true
# 提醒检查时间（cron表达式，默认每天早上7点）
PROACTIVE_REMINDER_CRON=0 7 * * *

# 检索增强配置
# 启用搜索解释（默认开启）
SEARCH_EXPLANATION_ENABLED=true
# 启用搜索建议（默认开启）
SEARCH_SUGGESTION_ENABLED=true
